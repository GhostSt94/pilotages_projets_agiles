# Port d'écoute de l'API
PORT=4000

# Chaîne de connexion MongoDB (local ou MongoDB Atlas)
MONGODB_URI=mongodb://127.0.0.1:27017/cadence

# Secret de signature des jetons JWT (à changer en production)
JWT_SECRET=change-me-in-production

# Durée de validité des jetons JWT
JWT_EXPIRES_IN=7d

# Origine(s) autorisée(s) pour CORS (séparées par des virgules), * pour tout autoriser
CORS_ORIGIN=*
